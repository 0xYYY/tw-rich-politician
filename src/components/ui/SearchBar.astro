---
interface Props {
  inputId: string;
  clearId?: string;
  placeholder?: string;
  className?: string;
  inputClass?: string;
}

const {
  inputId,
  clearId = `${inputId}-clear`,
  placeholder = '搜尋...',
  className = '',
  inputClass = 'text-base',
} = Astro.props;
---

<div class={`search-bar w-full ${className}`.trim()}>
  <div class="search-bar-inner">
    <span class="search-icon" aria-hidden="true">🔍</span>
    <input
      id={inputId}
      class={`search-input ${inputClass}`.trim()}
      type="text"
      placeholder={placeholder}
    />
    <button type="button" class="search-clear hidden" id={clearId} aria-label="清除搜尋">×</button>
  </div>
</div>

<style>
  .search-bar-inner {
    display: flex;
    width: 100%;
    min-width: 0;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: var(--color-surface);
    padding: 8px 10px;
  }
  .search-icon {
    flex-shrink: 0;
    font-size: 13px;
    line-height: 1;
    opacity: 0.7;
  }
  .search-input {
    min-width: 0;
    flex: 1;
    color: var(--color-text);
  }
  .search-input::placeholder {
    color: var(--color-text-muted);
  }
  .search-clear {
    width: 20px;
    height: 20px;
    border-radius: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    line-height: 1;
    color: var(--color-text-muted);
    background: var(--color-border-light);
    flex-shrink: 0;
  }
  .search-clear.hidden {
    display: none !important;
  }
</style>
