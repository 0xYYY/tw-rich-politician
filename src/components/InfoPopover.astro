---
interface Props {
  label?: string;
}

const { label = '了解更多' } = Astro.props;
---

<details class="info-popover">
  <summary>
    <span class="info-icon">💡</span>
    <span>{label}</span>
  </summary>
  <button type="button" class="info-backdrop" aria-label="關閉說明"></button>
  <div class="info-panel">
    <button type="button" class="info-close" aria-label="關閉">✕</button>
    <div class="info-body">
      <slot />
    </div>
  </div>
</details>

<script>
  const popovers = Array.from(document.querySelectorAll('.info-popover'));

  function closePopover(popover) {
    popover.removeAttribute('open');
  }

  popovers.forEach((popover) => {
    const backdrop = popover.querySelector('.info-backdrop');
    const closeBtn = popover.querySelector('.info-close');

    backdrop?.addEventListener('click', () => closePopover(popover));
    closeBtn?.addEventListener('click', () => closePopover(popover));
  });

  document.addEventListener('click', (e) => {
    for (const popover of popovers) {
      if (!popover.hasAttribute('open')) continue;
      if (popover.contains(e.target)) continue;
      closePopover(popover);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    for (const popover of popovers) {
      if (!popover.hasAttribute('open')) continue;
      closePopover(popover);
    }
  });
</script>
