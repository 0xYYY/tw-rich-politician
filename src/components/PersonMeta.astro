---
import {
  getPartyAreaTextColor,
  getPartyColor,
  getPartyNameTextColor,
  getPersonInfo,
} from '../lib/data';

interface Props {
  name: string;
  party: string | null;
}

const { name, party } = Astro.props;
const info = getPersonInfo(name);
if (!info) {
  throw new Error(`Missing person info for ${name}`);
}
---

<span
  class="person-meta person-meta-grid"
  style={`--party-color:${getPartyColor(party)};--party-area-text:${getPartyAreaTextColor(party)};--party-name-text:${getPartyNameTextColor(party)};`}
  title={`${info.party || party || '無黨籍'} · ${info.type === 'mayor' ? '縣市首長' : '立法委員'} · ${info.area}`}
>
  <span class="person-meta-emoji">{info.type === 'mayor' ? '🏙️' : '🏛️'}</span>
  <span class="person-meta-area">{info.area}</span>
  <span class="person-meta-name">{name}</span>
</span>
