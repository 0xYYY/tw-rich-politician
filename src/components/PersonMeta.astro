---
import { getPartyBgColor, getPartyColor, getPartyShortName, getPersonInfo } from '../lib/data';

interface Props {
  name: string;
  party: string | null;
}

const { name, party } = Astro.props;
const info = getPersonInfo(name);
if (!info) {
  throw new Error(`Missing person info for ${name}`);
}
---

<span class="person-meta" title={`${info.party || party || '無黨籍'} · ${info.type === 'mayor' ? '縣市首長' : '立法委員'} · ${info.area}`}>
  <span class="person-meta-top" style={`background:${getPartyBgColor(party)}`}>
    <span class="person-meta-party">{getPartyShortName(party)}</span>
    <span class="person-meta-type">{info.type === 'mayor' ? '🏙️' : '🏛️'}</span>
    <span class="person-meta-area">{info.area}</span>
  </span>
  <span class="person-meta-name" style={`color:${getPartyColor(party)}`}>{name}</span>
</span>
