---
import Layout from '../layouts/Layout.astro';
import { getRealEstateRankings, formatPing, parseCity, getPeopleMap } from '../lib/data';
import PersonMeta from '../components/PersonMeta.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import SegmentedToggle from '../components/ui/SegmentedToggle.astro';
import SearchBar from '../components/ui/SearchBar.astro';

const rankings = getRealEstateRankings('ping');
const peopleMap = getPeopleMap();

const REAL_ESTATE_TIER_COLORS = {
  low: '#8C7A63',   // < 50
  mid: '#5A6F7B',   // 50 ~ 100
  high: '#7A5E8E',  // > 100
} as const;

function getRealEstateTier(ping: number) {
  if (ping > 100) return { key: 'high', color: REAL_ESTATE_TIER_COLORS.high } as const;
  if (ping >= 50) return { key: 'mid', color: REAL_ESTATE_TIER_COLORS.mid } as const;
  return { key: 'low', color: REAL_ESTATE_TIER_COLORS.low } as const;
}
---

<Layout title="🏠 不動產" fullBleed={true} bodyClass="blueprint-theme page-accent-purple">
  <div class="blueprint-page min-h-dvh">
    <section class="border-b border-[var(--border-grid)]">
      <div class="mx-auto w-full max-w-6xl px-5 pb-10 pt-6 md:px-8 md:pb-12 md:pt-8">
        <PageHeader title="🏠 不動產" subtitle="依申報資料推算之持分後坪數">
          <p>坪數不代表市價與實際可使用面積，僅供跨人比較。</p>
          <p>本頁計算皆包含本人、配偶及未成年子女之申報資料。</p>
        </PageHeader>

        <div class="mb-6 flex items-center justify-between gap-2">
          <div class="min-w-0 flex-1 overflow-x-auto">
            <div class="flex w-max items-center gap-2 whitespace-nowrap">
              <div class="flex items-center gap-1"><div class="h-2.5 w-2.5 shrink-0 rounded-none" style={`background:${REAL_ESTATE_TIER_COLORS.high};`}></div><span class="font-[var(--font-mono)] text-[10px] text-[var(--color-text-muted)]">&gt; 100 坪</span></div>
              <div class="flex items-center gap-1"><div class="h-2.5 w-2.5 shrink-0 rounded-none" style={`background:${REAL_ESTATE_TIER_COLORS.mid};`}></div><span class="font-[var(--font-mono)] text-[10px] text-[var(--color-text-muted)]">50 ~ 100 坪</span></div>
              <div class="flex items-center gap-1"><div class="h-2.5 w-2.5 shrink-0 rounded-none" style={`background:${REAL_ESTATE_TIER_COLORS.low};`}></div><span class="font-[var(--font-mono)] text-[10px] text-[var(--color-text-muted)]">&lt; 50 坪</span></div>
            </div>
          </div>
          <SegmentedToggle
            id="sort-toggle"
            className="ml-2 shrink-0 sort-toggle"
            variant="sort"
            active="ping"
            dataKey="sort"
            items={[
              { value: 'ping', label: '依總坪數' },
              { value: 'count', label: '依筆數' },
            ]}
          />
        </div>

        <div class="mb-4 flex gap-3">
          <SearchBar inputId="search-input" clearId="search-clear" placeholder="搜尋姓名或選區/縣市..." />
        </div>

        <div class="mb-6 flex flex-col gap-3" id="ranking-list">
          {rankings.map((r, i) => {
            const tierCounts = { low: 0, mid: 0, high: 0 };
            for (const b of r.buildings) {
              const tier = getRealEstateTier(b.effectiveAreaPing);
              tierCounts[tier.key]++;
            }
            return (
              <div
                class={`bp-crosshair rank-card overflow-hidden rounded-none bg-[var(--color-surface)] ${i === 0 ? 'expanded' : ''}`}
                data-ping={r.totalPing.toFixed(2)}
                data-count={r.propertyCount}
                data-name={r.name}
                data-area={peopleMap[r.name]?.area || ''}
                data-party={r.party}
                data-buildings={JSON.stringify(r.buildings)}
              >
                <div class="flex cursor-pointer items-center gap-3 px-4 py-3.5" data-expandable>
                  <span class="rank-num w-6 shrink-0 text-right font-[var(--font-mono)] text-sm font-bold">{i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : i + 1}</span>
                  <div class="rank-info flex flex-1 flex-col gap-0.5">
                    <PersonMeta name={r.name} party={r.party} />
                  </div>
                  <div class="flex shrink-0 flex-col items-end gap-0.5">
                    <span class="font-[var(--font-mono)] text-base font-extrabold tabular-nums">
                      {r.totalPing > 0 ? formatPing(r.totalPing) : '0'}
                      <span class="text-xs font-medium text-[var(--color-text-muted)]">坪</span>
                    </span>
                    <span class="font-[var(--font-mono)] text-xs text-[var(--color-text-muted)]">
                      <span class="font-bold text-[var(--color-text-secondary)]">{r.propertyCount.toLocaleString('en-US')}</span> 筆
                      <span class="ml-1 inline-flex items-center gap-1.5">
                        <span>(</span>
                        <span class="inline-flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-none" style={`background:${REAL_ESTATE_TIER_COLORS.high};`}></span><span class="font-bold text-[var(--color-text-secondary)]">{tierCounts.high.toLocaleString('en-US')}</span></span>
                        <span class="inline-flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-none" style={`background:${REAL_ESTATE_TIER_COLORS.mid};`}></span><span class="font-bold text-[var(--color-text-secondary)]">{tierCounts.mid.toLocaleString('en-US')}</span></span>
                        <span class="inline-flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-none" style={`background:${REAL_ESTATE_TIER_COLORS.low};`}></span><span class="font-bold text-[var(--color-text-secondary)]">{tierCounts.low.toLocaleString('en-US')}</span></span>
                        <span>)</span>
                      </span>
                    </span>
                  </div>
                  <svg class="chevron shrink-0 text-[var(--color-text-muted)] transition-transform duration-200" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
                {r.buildings.length > 0 && (
                  <div class="cards-container">
                    {r.buildings
                      .sort((a, b) => b.effectiveAreaPing - a.effectiveAreaPing)
                      .map(b => {
                        const { city, detail } = parseCity(b.location);
                        const tierColor = getRealEstateTier(b.effectiveAreaPing).color;
                        return (
                          <div class="building-card min-w-0 overflow-hidden rounded-none border-2" style={`border-color: ${tierColor};`}>
                          <div class="flex items-center justify-center px-1.5 py-[5px]" style={`background: ${tierColor};`}>
                              <span class="text-[12px] font-extrabold tracking-[0.03em] text-white">{city}</span>
                          </div>
                          <div class="flex flex-col items-center gap-0.5 bg-[var(--color-surface)] px-1.5 py-2">
                              <span class="text-[9px] text-[var(--color-text-secondary)]">{detail}</span>
                              <span class="inline-flex items-baseline justify-center gap-1">
                                <span aria-hidden="true" class="select-none text-[9px] text-transparent">坪</span>
                                <span class="font-[var(--font-mono)] text-xl font-extrabold" style={`color: ${tierColor};`}>{formatPing(b.effectiveAreaPing)}</span>
                                <span class="text-[9px] text-[var(--color-text-muted)]">坪</span>
                              </span>
                          </div>
                          </div>
                        );
                      })}
                  </div>
                )}
              </div>
            );
          })}
        </div>

      </div>
    </section>
  </div>
</Layout>

<style>
  .hidden { display: none; }

  /* Rank number colors */
  .rank-num { color: var(--color-text-muted); }
  .rank-card.filtered-out { display: none !important; }
  .rank-card.expanded .chevron { transform: rotate(180deg); }

  /* Expand/collapse property cards */
  .cards-container {
    display: none;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    padding: 0 16px 14px;
  }
  .rank-card.expanded .cards-container { display: grid; }
</style>

<script>
  function formatRankLabel(rank) {
    if (rank === 1) return '🥇';
    if (rank === 2) return '🥈';
    if (rank === 3) return '🥉';
    return String(rank);
  }

  function normalizeSearchText(value) {
    return value.toLowerCase().replace(/台/g, '臺');
  }

  // Expand/collapse
  document.querySelectorAll('[data-expandable]').forEach(header => {
    header.addEventListener('click', () => {
      header.closest('.rank-card')?.classList.toggle('expanded');
    });
  });

  // Sort toggle
  const toggle = document.getElementById('sort-toggle')!;
  const list = document.getElementById('ranking-list')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const searchClear = document.getElementById('search-clear') as HTMLButtonElement | null;

  function updateVisibleRanks() {
    let rank = 1;
    const cards = Array.from(list.querySelectorAll('.rank-card'));
    cards.forEach(card => {
      const num = card.querySelector('.rank-num');
      if (!num || card.classList.contains('filtered-out')) return;
      num.textContent = formatRankLabel(rank++);
    });
  }

  function applySearchFilter() {
    if (!searchInput) return;
    const query = normalizeSearchText(searchInput.value.trim());
    const cards = Array.from(list.querySelectorAll('.rank-card'));
    cards.forEach(card => {
      const name = normalizeSearchText(card.getAttribute('data-name') || '');
      const area = normalizeSearchText(card.getAttribute('data-area') || '');
      const matched = query === '' || name.includes(query) || area.includes(query);
      card.classList.toggle('filtered-out', !matched);
    });
    searchClear?.classList.toggle('hidden', query.length === 0);
    updateVisibleRanks();
  }

  toggle.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.toggle-btn');
    if (!btn) return;

    toggle.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const sortBy = btn.getAttribute('data-sort');
    const cards = Array.from(list.querySelectorAll('.rank-card'));
    const expandedNames = new Set(
      cards
        .filter(card => card.classList.contains('expanded'))
        .map(card => card.getAttribute('data-name') || '')
    );

    cards.sort((a, b) => {
      if (sortBy === 'count') {
        const countDiff = Number(b.getAttribute('data-count')) - Number(a.getAttribute('data-count'));
        if (countDiff !== 0) return countDiff;
        return Number(b.getAttribute('data-ping')) - Number(a.getAttribute('data-ping'));
      }
      return Number(b.getAttribute('data-ping')) - Number(a.getAttribute('data-ping'));
    });

    // Re-render
    cards.forEach(card => list.appendChild(card));
    cards.forEach(card => {
      const name = card.getAttribute('data-name') || '';
      card.classList.toggle('expanded', expandedNames.has(name));
    });
    updateVisibleRanks();
  });

  searchInput?.addEventListener('input', applySearchFilter);
  searchClear?.addEventListener('click', () => {
    if (!searchInput) return;
    searchInput.value = '';
    applySearchFilter();
    searchInput.focus();
  });
</script>
