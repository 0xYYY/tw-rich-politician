---
import Layout from '../layouts/Layout.astro';
import { getDepositRankings, formatAmount, getPeopleMap } from '../lib/data';
import PersonMeta from '../components/PersonMeta.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import SearchBar from '../components/ui/SearchBar.astro';

const rankings = getDepositRankings();
const peopleMap = getPeopleMap();
---

<Layout title="💰 存款排名" fullBleed={true} bodyClass="blueprint-theme page-accent-orange">
  <div class="blueprint-page min-h-dvh">
    <section class="border-b border-[var(--border-grid)]">
      <div class="mx-auto w-full max-w-6xl px-5 pb-10 pt-6 md:px-8 md:pb-12 md:pt-8">
        <PageHeader title="💰 存款排名" subtitle="統計包含現金存款、債券與基金受益憑證">
          <p>本頁將存款、債券、基金受益憑證合併計算。</p>
          <p>外幣折算以申報時間揭露基礎為主，不代表即時匯率結果。</p>
          <p>本頁計算皆包含本人、配偶及未成年子女之申報資料。</p>
        </PageHeader>

        <section class="bp-crosshair mb-[var(--section-gap)] border border-[var(--border-grid)] p-3">
          <p class="mb-2 text-sm text-[var(--color-text-secondary)]">輸入你的存款金額，看看你排第幾名</p>
          <div class="flex items-center gap-2">
            <div class="flex min-w-0 flex-1 items-center gap-2 border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2">
              <span class="whitespace-nowrap text-[15px] text-[var(--color-text)]">新台幣</span>
              <input class="min-w-0 flex-1 font-[var(--font-mono)] text-base text-[var(--color-text)] placeholder:text-[var(--color-text-muted)]" type="number" id="user-amount" placeholder="0" min="0" />
              <span class="whitespace-nowrap text-[15px] text-[var(--color-text-muted)]">萬</span>
            </div>
            <button class="confirm-btn shrink-0 whitespace-nowrap px-4 py-2.5 text-[13px] font-bold transition-opacity duration-150 active:opacity-70" id="confirm-btn">查看排名</button>
          </div>
        </section>

        <section class="mb-[var(--section-gap)]">
          <div class="mb-4 flex gap-3">
            <SearchBar inputId="search-input" clearId="search-clear" placeholder="搜尋姓名或選區/縣市..." />
          </div>

          <div id="ranking-list" class="flex flex-col gap-0.5">
            {rankings.map((l, i) => {
              return (
                <div
                  class="bp-crosshair rank-card overflow-hidden rounded-none bg-[var(--color-surface)]"
                  data-amount={l.depositsTotal}
                  data-deposits={JSON.stringify(l.deposits)}
                  data-name={l.name}
                  data-area={peopleMap[l.name]?.area || ''}
                  data-has-data={l.hasData ? '1' : '0'}
                >
                  <div class="rank-row" data-expandable>
                    <span class="rank-num">{i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : i + 1}</span>
                    <span class="rank-name-wrap">
                      <PersonMeta name={l.name} party={l.party} />
                    </span>
                    <span class="rank-amount-text">{l.hasData ? formatAmount(l.depositsTotal) : '無資料'}</span>
                    <svg class="chevron shrink-0 text-[var(--color-text-muted)] transition-transform duration-200" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      </div>
    </section>
  </div>
</Layout>

<style>
  .hidden { display: none; }

  /* Row layout: rank | name | amount | bar */
  .rank-row {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 14px;
    cursor: pointer;
  }
  .rank-card.open .chevron { transform: rotate(180deg); }
  .rank-card.filtered-out { display: none !important; }

  .confirm-btn {
    border: 1px solid color-mix(in srgb, var(--page-accent) 55%, var(--border-grid));
    background: color-mix(in srgb, var(--page-accent) 20%, transparent);
    color: var(--color-text);
  }

  .rank-num {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    width: 24px;
    text-align: right;
    flex-shrink: 0;
    color: var(--color-text-muted);
  }
  .rank-name-wrap {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    min-width: 0;
  }
  .rank-amount-text {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-secondary);
    white-space: nowrap;
    width: 72px;
    margin-left: auto;
    text-align: right;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  /* Deposit breakdown — JS-injected */
  :global(.deposit-breakdown) {
    display: none;
    flex-direction: column;
    gap: 0;
    padding: 0 34px 10px 20px;
    background: rgba(26, 26, 28, 0.36);
    border-top: 1px solid var(--color-border-light);
  }
  :global(.deposit-breakdown.open) { display: flex; }
  :global(.deposit-item) {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  :global(.deposit-item:last-child) { border-bottom: none; }
  :global(.dep-label) {
    display: flex;
    align-items: center;
    gap: 4px;
    width: 56px;
    flex-shrink: 0;
    overflow: hidden;
  }
  :global(.dep-flag) { font-size: 13px; flex-shrink: 0; }
  :global(.dep-currency) {
    font-size: 12px;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.dep-amount) {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-secondary);
    white-space: nowrap;
    width: 56px;
    text-align: right;
    flex-shrink: 0;
  }
  :global(.dep-bar-wrap) {
    flex: 1;
    min-width: 36px;
    height: 6px;
    background: var(--color-border-light);
    border-radius: 0;
    overflow: hidden;
  }
  :global(.dep-bar) {
    height: 100%;
    border-radius: 0;
  }
  :global(.dep-pct) {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
    width: 32px;
    text-align: right;
    flex-shrink: 0;
  }

  /* User row — orange highlight */
  :global(.user-row) {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    background:
      radial-gradient(circle at 1px 1px, color-mix(in srgb, var(--page-accent) 16%, transparent) 1px, transparent 0) 0 0 / 10px 10px,
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 88%, transparent), color-mix(in srgb, var(--bg-base) 90%, transparent));
    border-radius: 0;
    padding: 12px 16px;
    margin: 6px 0;
    border: 1px solid color-mix(in srgb, var(--page-accent) 55%, var(--color-border));
    cursor: default;
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.02em;
    gap: 6px;
    overflow: hidden;
    isolation: isolate;
  }
  :global(.user-row::before) {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--color-border-light) 65%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--color-border-light) 65%, transparent) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.12;
    pointer-events: none;
    z-index: -1;
  }
  :global(.user-row.pop-in) {
    animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  :global(.user-row-arrow) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
    will-change: transform, opacity;
  }
  :global(.user-row-text) {
    white-space: nowrap;
  }
  :global(.user-row.pop-in .user-row-arrow--left) {
    animation: arrowInLeft 0.45s cubic-bezier(0.22, 1, 0.36, 1) 0.06s both;
  }
  :global(.user-row.pop-in .user-row-arrow--right) {
    animation: arrowInRight 0.45s cubic-bezier(0.22, 1, 0.36, 1) 0.06s both;
  }
  @keyframes popIn {
    0% { opacity: 0; transform: scale(0.92); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes arrowInLeft {
    0% { opacity: 0; transform: translateX(-16px); }
    100% { opacity: 0.85; transform: translateX(0); }
  }
  @keyframes arrowInRight {
    0% { opacity: 0; transform: translateX(16px); }
    100% { opacity: 0.85; transform: translateX(0); }
  }

</style>

<script>
  const CURRENCY_FLAGS: Record<string, string> = {
    '新臺幣': '\u{1F1F9}\u{1F1FC}',
    '美元': '\u{1F1FA}\u{1F1F8}',
    '人民幣': '\u{1F1E8}\u{1F1F3}',
    '離岸人民幣': '\u{1F1E8}\u{1F1F3}',
    '日圓': '\u{1F1EF}\u{1F1F5}',
    '歐元': '\u{1F1EA}\u{1F1FA}',
    '港幣': '\u{1F1ED}\u{1F1F0}',
    '英鎊': '\u{1F1EC}\u{1F1E7}',
    '澳幣': '\u{1F1E6}\u{1F1FA}',
    '加拿大幣': '\u{1F1E8}\u{1F1E6}',
    '新加坡幣': '\u{1F1F8}\u{1F1EC}',
    '紐西蘭幣': '\u{1F1F3}\u{1F1FF}',
    '南非幣': '\u{1F1FF}\u{1F1E6}',
    '墨西哥披索': '\u{1F1F2}\u{1F1FD}',
  };

  function fmtAmt(amount: number): string {
    if (amount >= 1_0000_0000) return `${(amount / 1_0000_0000).toFixed(1)} 億`;
    if (amount >= 1_0000) return `${Math.round(amount / 1_0000).toLocaleString('en-US')} 萬`;
    return amount.toLocaleString('en-US');
  }

  function normalizeSearchText(value: string): string {
    return value.toLowerCase().replace(/台/g, '臺');
  }

  const input = document.getElementById('user-amount') as HTMLInputElement;
  const confirmBtn = document.getElementById('confirm-btn')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const searchClear = document.getElementById('search-clear') as HTMLButtonElement | null;
  const list = document.getElementById('ranking-list')!;

  const allCards = Array.from(list.querySelectorAll('.rank-card')) as HTMLElement[];
  const amounts = allCards.map(card => Number(card.getAttribute('data-amount')));
  let animationId = 0; // incremented to cancel running animations

  function formatRankLabel(rank: number): string {
    if (rank === 1) return '🥇';
    if (rank === 2) return '🥈';
    if (rank === 3) return '🥉';
    return String(rank);
  }

  function updateVisibleRanks() {
    let rank = 1;
    allCards.forEach(card => {
      const num = card.querySelector('.rank-num');
      if (!num || card.classList.contains('filtered-out')) return;
      num.textContent = formatRankLabel(rank++);
    });
  }

  function applySearchFilter() {
    if (!searchInput) return;
    const query = normalizeSearchText(searchInput.value.trim());
    allCards.forEach(card => {
      const name = normalizeSearchText(card.getAttribute('data-name') || '');
      const area = normalizeSearchText(card.getAttribute('data-area') || '');
      const matched = query === '' || name.includes(query) || area.includes(query);
      card.classList.toggle('filtered-out', !matched);
    });
    const userRow = list.querySelector('.user-row') as HTMLElement | null;
    if (userRow) {
      userRow.style.display = query.length > 0 ? 'none' : '';
    }
    searchClear?.classList.toggle('hidden', query.length === 0);
    updateVisibleRanks();
  }

  // --- Deposit breakdown click ---
  list.addEventListener('click', (e) => {
    const header = (e.target as HTMLElement).closest('[data-expandable]');
    if (!header) return;
    const card = header.closest('.rank-card') as HTMLElement | null;
    if (!card) return;

    // Toggle existing breakdown
    const existing = card.querySelector('.deposit-breakdown') as HTMLElement | null;
    if (existing) {
      const willOpen = !existing.classList.contains('open');
      existing.classList.toggle('open', willOpen);
      card.classList.toggle('open', willOpen);
      return;
    }

    if (card.getAttribute('data-has-data') !== '1') return;

    const depositsStr = card.getAttribute('data-deposits');
    if (!depositsStr) return;
    const deposits = JSON.parse(depositsStr) as { currency: string; amount: number }[];
    if (deposits.length === 0) return;

    deposits.sort((a, b) => b.amount - a.amount);

    const total = deposits.reduce((s, d) => s + d.amount, 0);
    const breakdown = document.createElement('div');
    breakdown.className = 'deposit-breakdown open';
    const neutralBarColor = 'color-mix(in srgb, var(--color-text-secondary) 55%, var(--bg-base))';
    const depositRows = deposits.map(d => {
      const flag = CURRENCY_FLAGS[d.currency] || '\u{1F4B0}';
      const pctVal = total > 0 ? (d.amount / total) * 100 : 0;
      return `<div class="deposit-item">
        <span class="dep-label"><span class="dep-flag">${flag}</span><span class="dep-currency">${d.currency}</span></span>
        <span class="dep-amount">${fmtAmt(d.amount)}</span>
        <div class="dep-bar-wrap"><div class="dep-bar" style="width:${pctVal}%;background:${neutralBarColor};"></div></div>
        <span class="dep-pct">${pctVal.toFixed(0)}%</span>
      </div>`;
    }).join('');

    breakdown.innerHTML = depositRows;
    card.appendChild(breakdown);
    card.classList.add('open');
  });

  // Default-expand the first visible row with deposit data.
  const firstDataCard = allCards.find(card => card.getAttribute('data-has-data') === '1');
  const firstDataHeader = firstDataCard?.querySelector('[data-expandable]');
  if (firstDataHeader) {
    firstDataHeader.dispatchEvent(new MouseEvent('click', { bubbles: true }));
  }

  // --- Helpers ---
  const delay = (ms: number) => new Promise(r => setTimeout(r, ms));

  function resetState() {
    list.querySelector('.user-row')?.remove();
  }

  // Wait for smooth scroll to finish (polls until scroll stops)
  function waitForScrollEnd(): Promise<void> {
    return new Promise(resolve => {
      let lastY = window.scrollY;
      let stable = 0;
      const check = () => {
        if (window.scrollY === lastY) {
          stable++;
          if (stable > 3) { resolve(); return; }
        } else {
          stable = 0;
          lastY = window.scrollY;
        }
        requestAnimationFrame(check);
      };
      requestAnimationFrame(check);
    });
  }

  // --- Animated ranking ---
  async function animateToRank() {
    const wan = Number(input.value) || 0;
    if (wan <= 0) return;

    const userAmount = wan * 10000;
    const thisAnimId = ++animationId;

    // Find target position
    let targetPos = amounts.findIndex(a => userAmount >= a);
    if (targetPos === -1) targetPos = amounts.length;

    // Clean up previous state
    resetState();

    // Close any open breakdowns
    list.querySelectorAll('.deposit-breakdown.open').forEach(el => {
      el.classList.remove('open');
    });
    list.querySelectorAll('.rank-card.open').forEach(card => {
      card.classList.remove('open');
    });

    // Step 1: Scroll to where the user row will land (center of viewport)
    const anchorRow = allCards[targetPos] || allCards[allCards.length - 1];
    if (anchorRow) {
      anchorRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
      await waitForScrollEnd();
      if (animationId !== thisAnimId) return;
    }

    // Small pause after scroll settles
    await delay(200);
    if (animationId !== thisAnimId) return;

    // Step 2: Insert user row at the correct position with pop-in animation
    const label = fmtAmt(userAmount);

    const userRow = document.createElement('div');
    userRow.className = 'user-row pop-in';
    userRow.innerHTML = `<span class="user-row-arrow user-row-arrow--left" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span><span class="user-row-text">你的 ${label} 存款排名在這</span><span class="user-row-arrow user-row-arrow--right" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></span>`;

    if (targetPos < allCards.length) {
      allCards[targetPos].before(userRow);
    } else {
      list.appendChild(userRow);
    }

    if (searchInput && searchInput.value.trim().length > 0) {
      userRow.style.display = 'none';
    }

    // No rank number shift — other rows keep their original numbers

    // Remove pop-in class after animation completes
    userRow.addEventListener('animationend', (event) => {
      if (event.target !== userRow || event.animationName !== 'popIn') return;
      userRow.classList.remove('pop-in');
    }, { once: true });
  }

  // --- Button click ---
  confirmBtn.addEventListener('click', animateToRank);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') animateToRank();
  });
  searchInput?.addEventListener('input', applySearchFilter);
  searchClear?.addEventListener('click', () => {
    if (!searchInput) return;
    searchInput.value = '';
    applySearchFilter();
    searchInput.focus();
  });
</script>
