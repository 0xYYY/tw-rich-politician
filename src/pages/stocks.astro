---
import Layout from '../layouts/Layout.astro';
import { getAllPeople, getPartyColor, getPeopleMap } from '../lib/data';
import PersonMeta from '../components/PersonMeta.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import SegmentedToggle from '../components/ui/SegmentedToggle.astro';
import SearchBar from '../components/ui/SearchBar.astro';
import stockPriceCache from '../../data/stock-price-cache.json';

interface LegislatorStockItem {
  name: string;
  ticker: string | null;
  exchangeTicker: string;
  shares: number;
  owner: string;
  priceAtDisclosure: number | null;
  latestPrice: number | null;
}

interface LegislatorStockHolding {
  name: string;
  party: string | null;
  date: string;
  hasData: boolean;
  stockCount: number;
  totalShares: number;
  totalCurrentValue: number;
  totalReturnValue: number;
  totalReturnPct: number | null;
  hasCurrentValueData: boolean;
  hasReturnData: boolean;
  stocks: LegislatorStockItem[];
}

interface StockHolderEntry {
  legislator: string;
  party: string | null;
  owner: string;
  shares: number;
  value: number | null;
}

interface StockAggregate {
  key: string;
  name: string;
  displayName: string;
  ticker: string | null;
  exchangeTicker: string;
  holderCount: number;
  totalShares: number;
  totalValue: number;
  holders: StockHolderEntry[];
}

const FOREIGN_ENGLISH_NAME_BY_TICKER: Record<string, string> = {
  AAPL: 'Apple',
  BABA: 'Alibaba Group',
  BA: 'Boeing',
  AMWL: 'American Well',
  TSM: 'TSMC ADR',
  AMD: 'AMD',
  BIDU: 'Baidu ADR',
  NIO: 'NIO',
  CCL: 'Carnival Corp',
  COIN: 'Coinbase',
  RIVN: 'Rivian',
  RBLX: 'Roblox',
  TSLA: 'Tesla',
  MSFT: 'Microsoft',
  PYPL: 'PayPal',
  NVAX: 'Novavax',
  LCID: 'Lucid Group',
  NOK: 'Nokia',
  SHOP: 'Shopify',
  PLTR: 'Palantir',
  INTC: 'Intel',
  NVDA: 'NVIDIA',
  SE: 'Sea Ltd',
  SY: 'So-Young',
};

const FOREIGN_EXCHANGE_BY_TICKER: Record<string, string> = {
  AAPL: 'NASDAQ',
  BABA: 'NYSE',
  BA: 'NYSE',
  AMWL: 'NYSE',
  TSM: 'NYSE',
  AMD: 'NASDAQ',
  BIDU: 'NASDAQ',
  NIO: 'NYSE',
  CCL: 'NYSE',
  COIN: 'NASDAQ',
  RIVN: 'NASDAQ',
  RBLX: 'NYSE',
  TSLA: 'NASDAQ',
  MSFT: 'NASDAQ',
  PYPL: 'NASDAQ',
  NVAX: 'NASDAQ',
  LCID: 'NASDAQ',
  NOK: 'NYSE',
  SHOP: 'NYSE',
  PLTR: 'NASDAQ',
  INTC: 'NASDAQ',
  NVDA: 'NASDAQ',
  SE: 'NYSE',
  SY: 'NASDAQ',
};

function formatExchangeTicker(ticker: string | null): string {
  if (!ticker) return 'N/A';
  const normalized = ticker.toUpperCase();
  if (/^\d+$/.test(normalized)) return `TWSE:${normalized}`;
  return `${FOREIGN_EXCHANGE_BY_TICKER[normalized] || 'US'}:${normalized}`;
}

function getDisplayStockName(name: string, ticker: string | null): string {
  if (!ticker) return name;
  const normalized = ticker.toUpperCase();
  return FOREIGN_ENGLISH_NAME_BY_TICKER[normalized] || name;
}

function formatCompactTwd(amount: number): string {
  if (!Number.isFinite(amount) || amount <= 0) return 'NT$ —';
  if (amount >= 1_0000_0000) return `NT$ ${(amount / 1_0000_0000).toFixed(1)} 億`;
  if (amount >= 1_0000) return `NT$ ${(amount / 1_0000).toFixed(1)} 萬`;
  return `NT$ ${Math.round(amount).toLocaleString('en-US')}`;
}

function formatSignedCompactTwd(amount: number): string {
  if (!Number.isFinite(amount) || amount === 0) return 'NT$ 0';
  const sign = amount > 0 ? '+' : '-';
  return `${sign}${formatCompactTwd(Math.abs(amount))}`;
}

function formatSignedPct(pct: number | null): string {
  if (pct == null || !Number.isFinite(pct)) return '—';
  const sign = pct > 0 ? '+' : '';
  return `${sign}${pct.toFixed(1)}%`;
}

const allPeople = getAllPeople();
const peopleMap = getPeopleMap();
const personMap = new Map(allPeople.map(l => [l.name, l]));

const legislatorHoldings: LegislatorStockHolding[] = [];
const stockMap = new Map<string, { name: string; ticker: string | null; holders: StockHolderEntry[] }>();

for (const [name, info] of Object.entries(peopleMap)) {
  const l = personMap.get(name);
  const sourceStocks = l?.stocks || [];
  const stocks = sourceStocks
    .map(s => ({
      name: s.cleanName,
      ticker: s.ticker,
      exchangeTicker: formatExchangeTicker(s.ticker),
      shares: s.shares,
      owner: s.owner,
      priceAtDisclosure: s.priceAtDisclosure,
      latestPrice: s.latestPrice,
    }))
    .sort((a, b) => b.shares - a.shares);

  const totalShares = stocks.reduce((sum, s) => sum + s.shares, 0);
  const totalCurrentValue = stocks.reduce((sum, s) => sum + ((s.latestPrice ?? 0) * s.shares), 0);
  const totalReturnValue = stocks.reduce((sum, s) => {
    if (s.latestPrice == null || s.priceAtDisclosure == null) return sum;
    return sum + (s.latestPrice - s.priceAtDisclosure) * s.shares;
  }, 0);
  const totalReturnBase = stocks.reduce((sum, s) => {
    if (s.latestPrice == null || s.priceAtDisclosure == null) return sum;
    return sum + (s.priceAtDisclosure * s.shares);
  }, 0);
  const totalReturnPct = totalReturnBase > 0 ? (totalReturnValue / totalReturnBase) * 100 : null;
  const hasCurrentValueData = stocks.some(s => s.latestPrice != null);
  const hasReturnData = stocks.some(s => s.latestPrice != null && s.priceAtDisclosure != null);

  legislatorHoldings.push({
    name,
    party: l?.party || info.party || null,
    date: l?.date || '',
    hasData: !!l,
    stockCount: stocks.length,
    totalShares,
    totalCurrentValue,
    totalReturnValue,
    totalReturnPct,
    hasCurrentValueData,
    hasReturnData,
    stocks,
  });

  for (const s of stocks) {
    const key = s.ticker || s.name;
    const existing = stockMap.get(key);
    const value = s.latestPrice != null ? s.latestPrice * s.shares : null;
    if (!existing) {
      stockMap.set(key, {
        name: s.name,
        ticker: s.ticker,
        holders: [{
          legislator: l.name,
          party: l.party,
          owner: s.owner,
          shares: s.shares,
          value,
        }],
      });
      continue;
    }

    const holder = existing.holders.find(h => h.legislator === l.name);
    if (holder) {
      holder.shares += s.shares;
      holder.value = holder.value != null && value != null ? holder.value + value : null;
    } else {
      existing.holders.push({
        legislator: l.name,
        party: l.party,
        owner: s.owner,
        shares: s.shares,
        value,
      });
    }
  }
}

// Default sort for legislator view: by total current value
legislatorHoldings.sort((a, b) => b.totalCurrentValue - a.totalCurrentValue || b.totalReturnValue - a.totalReturnValue);

const stockHoldings: StockAggregate[] = Array.from(stockMap.entries()).map(([key, item]) => {
  const holders = item.holders.sort((a, b) => b.shares - a.shares);
  const holderCount = new Set(holders.map(h => h.legislator)).size;
  const totalShares = holders.reduce((sum, h) => sum + h.shares, 0);
  const totalValue = holders.reduce((sum, h) => sum + (h.value ?? 0), 0);

  return {
    key,
    name: item.name,
    displayName: getDisplayStockName(item.name, item.ticker),
    ticker: item.ticker,
    exchangeTicker: formatExchangeTicker(item.ticker),
    holderCount,
    totalShares,
    totalValue,
    holders,
  };
});

// Default view sort: by total value, then by number of legislators holding
stockHoldings.sort((a, b) => b.totalValue - a.totalValue || b.holderCount - a.holderCount);

const latestStockPriceDate = Object.keys(stockPriceCache)
  .filter((key) => !key.startsWith('USDTWD:'))
  .map((key) => key.match(/:(\d{4}-\d{2}-\d{2})$/)?.[1] || '')
  .filter(Boolean)
  .sort()
  .at(-1) || '';
---

<Layout title="📈 股票" fullBleed={true} bodyClass="blueprint-theme page-accent-red">
  <div class="blueprint-page min-h-dvh">
    <section class="border-b border-[var(--border-grid)]">
      <div class="mx-auto w-full max-w-6xl px-5 pb-10 pt-6 md:px-8 md:pb-12 md:pt-8">
  <PageHeader title="📈 股票" subtitle="報酬計算假設申報後持有至今">
    <p>市值為估算值；報酬計算假設申報後持有至今，未納入股利、交易成本與途中調整。</p>
    <p>海外標的先取美元報價，再換算為新臺幣，與實際申報口徑可能有差異。</p>
    <p>最新股價資料日期：{latestStockPriceDate || '—'}</p>
    <p>本頁計算皆包含本人、配偶及未成年子女之申報資料。</p>
  </PageHeader>

  <div class="mb-2 flex flex-wrap items-center gap-3">
    <SegmentedToggle
      id="view-toggle"
      variant="view"
      active="stock"
      dataKey="view"
      items={[
        { value: 'stock', label: '依股票看' },
        { value: 'legislator', label: '依人物看' },
      ]}
    />
    <SegmentedToggle
      id="stock-sort-toggle"
      className="ml-auto sort-toggle"
      variant="sort"
      active="value"
      dataKey="sort"
      items={[
        { value: 'value', label: '依總市值' },
        { value: 'person', label: '依持有人數' },
      ]}
    />
    <SegmentedToggle
      id="legislator-sort-toggle"
      className="ml-auto sort-toggle hidden"
      variant="sort"
      active="value"
      dataKey="sort"
      items={[
        { value: 'value', label: '依目前總值' },
        { value: 'return', label: '依總報酬' },
      ]}
    />
  </div>

  <div class="mb-2 flex gap-3" id="stock-search-controls">
    <SearchBar inputId="stock-search-input" clearId="stock-search-clear" placeholder="搜尋股票名稱或代號..." />
  </div>

  <div class="mb-2 flex gap-3 hidden" id="legislator-search-controls">
    <SearchBar inputId="legislator-search-input" clearId="legislator-search-clear" placeholder="搜尋姓名或選區/縣市..." />
  </div>

  <section id="stock-panel" class="panel active">
    <div id="stock-list" class="flex flex-col gap-0.5">
      {stockHoldings.map((s, i) => (
        <div
          class="bp-crosshair stock-card overflow-hidden rounded-none bg-[var(--color-surface)]"
          data-card-type="stock"
          data-person={s.holderCount}
          data-shares={s.totalShares}
          data-value={s.totalValue}
          data-name={s.name}
          data-display-name={s.displayName}
          data-ticker={s.ticker || ''}
          data-holders={JSON.stringify(s.holders)}
        >
          <div class="flex cursor-pointer items-center gap-2.5 px-3.5 py-3" data-expandable>
            <span class="rank-num w-6 shrink-0 text-right font-[var(--font-mono)] text-sm font-bold text-[var(--color-text-muted)]">{i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : i + 1}</span>
            <div class="flex min-w-0 flex-1 flex-row items-center gap-2">
              <span class="text-sm font-bold">{s.displayName}</span>
              <span class="whitespace-nowrap font-[var(--font-mono)] text-[11px] text-[var(--color-text-muted)]">{s.exchangeTicker}</span>
              <span class="ml-auto whitespace-nowrap font-[var(--font-mono)] text-[13px] font-bold text-[var(--color-text)]">{formatCompactTwd(s.totalValue)}（{s.holderCount.toLocaleString('en-US')}人）</span>
            </div>
            <svg class="chevron shrink-0 text-[var(--color-text-muted)] transition-transform duration-200" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="legislator-panel" class="panel">
    <div id="ranking-list" class="flex flex-col gap-0.5">
      {legislatorHoldings.map((h, i) => (
        <div
          class="bp-crosshair stock-card overflow-hidden rounded-none bg-[var(--color-surface)]"
          data-card-type="legislator"
          data-value={h.totalCurrentValue}
          data-return={h.totalReturnValue}
          data-name={h.name}
          data-area={peopleMap[h.name]?.area || ''}
          data-stocks={JSON.stringify(h.stocks)}
        >
          <div class="flex cursor-pointer items-center gap-2.5 px-3.5 py-3" data-expandable>
            <span class="rank-num w-6 shrink-0 text-right font-[var(--font-mono)] text-sm font-bold text-[var(--color-text-muted)]">{i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : i + 1}</span>
            <div class="min-w-0 flex-1">
              <div class="flex min-w-0 items-start gap-2">
                <PersonMeta name={h.name} party={h.party} />
              </div>
            </div>
            <div class="flex shrink-0 flex-col items-end gap-0.5">
              <span class="font-[var(--font-mono)] text-[13px] font-bold text-[var(--color-text)]">{h.hasCurrentValueData ? formatCompactTwd(h.totalCurrentValue) : 'NT$ —'}</span>
              <span class={`main-return font-[var(--font-mono)] text-[11px] ${h.hasReturnData ? (h.totalReturnValue > 0 ? 'gain' : (h.totalReturnValue < 0 ? 'loss' : '')) : ''}`}>
                報酬 {h.hasReturnData ? `${formatSignedCompactTwd(h.totalReturnValue)} / ${formatSignedPct(h.totalReturnPct)}` : 'NT$ — / —'}
              </span>
            </div>
            <svg class="chevron shrink-0 text-[var(--color-text-muted)] transition-transform duration-200" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>
      ))}
    </div>
  </section>
      </div>
    </section>
  </div>
</Layout>

<style>
  :global(body.page-accent-red) {
    /* Product requirement for this page: increase=red, loss=green */
    --color-gain: var(--accent-red);
    --color-loss: var(--accent-green);
  }

  .main-return { color: var(--color-text-muted); }
  .main-return.gain { color: var(--color-gain); }
  .main-return.loss { color: var(--color-loss); }

  /* JS-toggled state classes */
  .hidden { display: none; }
  .panel { display: none; }
  .panel.active { display: block; }
  .stock-card.filtered-out { display: none !important; }
  .stock-card.open .chevron { transform: rotate(180deg); }

  /* JS-injected breakdown styles */
  :global(.stock-breakdown) {
    display: none;
    flex-direction: column;
    gap: 0;
    padding: 0 38px 10px 34px;
    background-color: rgba(26, 26, 28, 0.36);
    background-image: radial-gradient(circle at 1px 1px, rgba(169, 177, 214, 0.08) 0.55px, transparent 0.75px);
    background-size: 7px 7px;
    border-top: 1px solid var(--color-border-light);
  }
  :global(.stock-breakdown.open) { display: flex; }
  :global(.stock-detail-row) {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border-light);
    font-size: 12px;
  }
  :global(.stock-detail-row:last-child) { border-bottom: none; }
  :global(.stock-detail-name) {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    font-size: 12px;
    font-weight: 700;
  }
  :global(.stock-detail-shares) {
    width: 88px;
    margin-left: 8px;
    text-align: right;
    white-space: nowrap;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  :global(.stock-detail-value) {
    width: 104px;
    text-align: right;
    white-space: nowrap;
    color: var(--color-text);
    font-weight: 700;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  :global(.stock-detail-ticker) {
    width: 98px;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    white-space: nowrap;
    flex-shrink: 0;
  }
  :global(.stock-detail-current) {
    width: 110px;
    text-align: right;
    white-space: nowrap;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
  :global(.stock-detail-return) {
    width: 130px;
    text-align: right;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
  :global(.stock-detail-return.gain) { color: var(--color-gain); }
  :global(.stock-detail-return.loss) { color: var(--color-loss); }
  :global(.stock-detail-owner) {
    width: 56px;
    text-align: right;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  :global(.stock-detail-spacer) {
    width: 0;
    flex-shrink: 0;
    visibility: hidden;
  }
  @media (max-width: 640px) {
    :global(.stock-breakdown) {
      padding: 0 38px 10px 20px;
    }
    :global(.stock-detail-row) {
      gap: 6px;
    }
    :global(.stock-detail-shares) {
      width: 80px;
      margin-left: 10px;
    }
    :global(.stock-detail-value) {
      width: 88px;
    }
  }
  :global(.leg-stock-item) {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  :global(.leg-stock-item:last-child) { border-bottom: none; }
  :global(.leg-stock-row) {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    min-width: 0;
  }
  :global(.leg-stock-head) {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    flex: 1;
  }
  :global(.leg-stock-name) {
    flex: 0 1 auto;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 12px;
    font-weight: 700;
  }
  :global(.leg-stock-exchange) {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  :global(.leg-stock-current) {
    margin-left: auto;
    width: 120px;
    text-align: right;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
    font-weight: 700;
  }
  :global(.leg-stock-shares) {
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  :global(.leg-stock-return) {
    margin-left: auto;
    width: 160px;
    text-align: right;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
  :global(.leg-stock-return.gain) { color: var(--color-gain); }
  :global(.leg-stock-return.loss) { color: var(--color-loss); }
</style>

<script define:vars={{ peopleMeta: peopleMap }}>
  const viewToggle = document.getElementById('view-toggle');
  const stockSearchControls = document.getElementById('stock-search-controls');
  const legislatorSearchControls = document.getElementById('legislator-search-controls');
  const stockPanel = document.getElementById('stock-panel');
  const legislatorPanel = document.getElementById('legislator-panel');
  const stockList = document.getElementById('stock-list');
  const legislatorList = document.getElementById('ranking-list');
  const stockSearchInput = document.getElementById('stock-search-input');
  const legislatorSearchInput = document.getElementById('legislator-search-input');
  const stockSearchClear = document.getElementById('stock-search-clear');
  const legislatorSearchClear = document.getElementById('legislator-search-clear');
  const stockSortToggle = document.getElementById('stock-sort-toggle');
  const legislatorSortToggle = document.getElementById('legislator-sort-toggle');

  if (
    !viewToggle ||
    !stockSearchControls ||
    !legislatorSearchControls ||
    !stockPanel ||
    !legislatorPanel ||
    !stockList ||
    !legislatorList ||
    !stockSearchInput ||
    !legislatorSearchInput ||
    !stockSearchClear ||
    !legislatorSearchClear ||
    !stockSortToggle ||
    !legislatorSortToggle
  ) {
    console.warn('[stocks] required DOM elements are missing');
  } else {
    const viewButtons = Array.from(viewToggle.querySelectorAll('.toggle-btn'));
    const stockSortButtons = Array.from(stockSortToggle.querySelectorAll('.toggle-btn'));
    const legislatorSortButtons = Array.from(legislatorSortToggle.querySelectorAll('.toggle-btn'));

    let currentView = 'stock';
    let currentStockSort = 'value';
    let currentLegislatorSort = 'value';

    function formatValue(value) {
      if (value == null) return '—';
      return `NT$${Math.round(value).toLocaleString('en-US')}`;
    }

    function formatCompactTwd(amount) {
      if (!Number.isFinite(amount) || amount <= 0) return 'NT$ —';
      if (amount >= 1_0000_0000) return `NT$ ${(amount / 1_0000_0000).toFixed(1)} 億`;
      if (amount >= 1_0000) return `NT$ ${(amount / 1_0000).toFixed(1)} 萬`;
      return `NT$ ${Math.round(amount).toLocaleString('en-US')}`;
    }

    function formatSignedCompactTwd(amount) {
      if (!Number.isFinite(amount) || amount === 0) return 'NT$ 0';
      const sign = amount > 0 ? '+' : '-';
      return `${sign}${formatCompactTwd(Math.abs(amount))}`;
    }

    function formatReturnPct(latestPrice, disclosurePrice) {
      if (latestPrice == null || disclosurePrice == null || disclosurePrice === 0) return '—';
      const pct = ((latestPrice - disclosurePrice) / disclosurePrice) * 100;
      const sign = pct > 0 ? '+' : '';
      return `${sign}${pct.toFixed(1)}%`;
    }

    function getReturnValue(latestPrice, disclosurePrice, shares) {
      if (latestPrice == null || disclosurePrice == null) return null;
      return (latestPrice - disclosurePrice) * shares;
    }

    function formatReturnLine(latestPrice, disclosurePrice, shares) {
      const ret = getReturnValue(latestPrice, disclosurePrice, shares);
      if (ret == null) return 'NT$ — / —';
      return `${formatSignedCompactTwd(ret)} / ${formatReturnPct(latestPrice, disclosurePrice)}`;
    }

    function getReturnClass(latestPrice, disclosurePrice, shares) {
      const ret = getReturnValue(latestPrice, disclosurePrice, shares);
      if (ret == null || ret === 0) return '';
      return ret > 0 ? 'gain' : 'loss';
    }

    function getPartyColor(party) {
      if (party === '民主進步黨') return 'var(--color-dpp)';
      if (party === '中國國民黨') return 'var(--color-kmt)';
      if (party === '台灣民眾黨') return 'var(--color-tpp)';
      return 'var(--color-independent)';
    }

    function getPartyAreaTextColor(party) {
      if (party === '民主進步黨') return '#103d1d';
      if (party === '中國國民黨') return '#dbe3ff';
      if (party === '台灣民眾黨') return '#083d3a';
      return '#1f2436';
    }

    function getPartyNameTextColor(party) {
      if (party === '中國國民黨') return '#7aa2f7';
      if (party === '民主進步黨') return 'var(--color-dpp)';
      if (party === '台灣民眾黨') return 'var(--color-tpp)';
      return 'var(--color-independent)';
    }

    function buildPersonMeta(name, party) {
      const info = peopleMeta[name];
      if (!info) return '';
      const typeIcon = info.type === 'mayor' ? '🏙️' : '🏛️';
      return `<span class="person-meta person-meta-grid" style="--party-color:${getPartyColor(party)};--party-area-text:${getPartyAreaTextColor(party)};--party-name-text:${getPartyNameTextColor(party)}"><span class="person-meta-emoji">${typeIcon}</span><span class="person-meta-area">${info.area}</span><span class="person-meta-name">${name}</span></span>`;
    }

    function formatRankLabel(rank) {
      if (rank === 1) return '🥇';
      if (rank === 2) return '🥈';
      if (rank === 3) return '🥉';
      return String(rank);
    }

    function normalizeSearchText(value) {
      return value.toLowerCase().replace(/台/g, '臺');
    }

    function applyView() {
      viewButtons.forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-view') === currentView);
      });

      stockPanel.classList.toggle('active', currentView === 'stock');
      legislatorPanel.classList.toggle('active', currentView === 'legislator');
      stockSortToggle.classList.toggle('hidden', currentView !== 'stock');
      stockSearchControls.classList.toggle('hidden', currentView !== 'stock');
      legislatorSortToggle.classList.toggle('hidden', currentView !== 'legislator');
      legislatorSearchControls.classList.toggle('hidden', currentView !== 'legislator');

      stockList.querySelectorAll('.stock-card.open').forEach(card => card.classList.remove('open'));
      legislatorList.querySelectorAll('.stock-card.open').forEach(card => card.classList.remove('open'));
      stockList.querySelectorAll('.stock-breakdown').forEach(el => el.remove());
      legislatorList.querySelectorAll('.stock-breakdown').forEach(el => el.remove());
    }

    function buildStockBreakdown(card) {
      const holdersStr = card.getAttribute('data-holders');
      if (!holdersStr) return null;

      const holders = JSON.parse(holdersStr);
      if (!holders.length) return null;

      const breakdown = document.createElement('div');
      breakdown.className = 'stock-breakdown open';
      breakdown.innerHTML = holders.map(h => `
      <div class="stock-detail-row">
        <span class="stock-detail-name">${buildPersonMeta(h.legislator, h.party)}</span>
        <span class="stock-detail-shares">${h.shares.toLocaleString('en-US')} 股</span>
        <span class="stock-detail-value">${formatCompactTwd(h.value ?? 0)}</span>
        <span class="stock-detail-spacer" aria-hidden="true"></span>
      </div>
    `).join('');
      return breakdown;
    }

    function buildLegislatorBreakdown(card) {
      const stocksStr = card.getAttribute('data-stocks');
      if (!stocksStr) return null;

      const stocks = JSON.parse(stocksStr);
      if (!stocks.length) return null;

      const sorted = [...stocks].sort((a, b) => ((b.latestPrice ?? 0) * b.shares) - ((a.latestPrice ?? 0) * a.shares));
      const breakdown = document.createElement('div');
      breakdown.className = 'stock-breakdown open';
      breakdown.innerHTML = sorted.map(s => `
      <div class="leg-stock-item">
        <div class="leg-stock-row">
          <div class="leg-stock-head">
            <span class="leg-stock-name">${s.name}</span>
            <span class="leg-stock-exchange">${s.exchangeTicker || 'N/A'}</span>
          </div>
          <span class="leg-stock-current">${formatCompactTwd((s.latestPrice ?? 0) * s.shares)}</span>
        </div>
        <div class="leg-stock-row">
          <span class="leg-stock-shares">${s.shares.toLocaleString('en-US')} 股</span>
          <span class="leg-stock-return ${getReturnClass(s.latestPrice, s.priceAtDisclosure, s.shares)}">
          ${formatReturnLine(s.latestPrice, s.priceAtDisclosure, s.shares)}
          </span>
        </div>
      </div>
    `).join('');
      return breakdown;
    }

    function sortCards(list, key) {
      const cards = Array.from(list.querySelectorAll('.stock-card'));
      cards.sort((a, b) => {
        const aVal = Number(a.getAttribute(`data-${key}`));
        const bVal = Number(b.getAttribute(`data-${key}`));
        return bVal - aVal;
      });

      cards.forEach((card, i) => {
        const num = card.querySelector('.rank-num');
        if (num) num.textContent = formatRankLabel(i + 1);
        list.appendChild(card);
      });
      updateVisibleRanks(list);
    }

    function updateVisibleRanks(list) {
      let rank = 1;
      const cards = Array.from(list.querySelectorAll('.stock-card'));
      for (const card of cards) {
        const num = card.querySelector('.rank-num');
        if (!num) continue;
        if (card.classList.contains('filtered-out')) continue;
        num.textContent = formatRankLabel(rank++);
      }
    }

    function applySearchFilter() {
      const stockQuery = normalizeSearchText(stockSearchInput.value.trim());
      const stockCards = Array.from(stockList.querySelectorAll('.stock-card'));
      stockCards.forEach(card => {
        const name = normalizeSearchText(card.getAttribute('data-display-name') || '');
        const fallback = normalizeSearchText(card.getAttribute('data-name') || '');
        const ticker = normalizeSearchText(card.getAttribute('data-ticker') || '');
        const matched = !stockQuery || name.includes(stockQuery) || fallback.includes(stockQuery) || ticker.includes(stockQuery);
        card.classList.toggle('filtered-out', !matched);
        if (!matched) card.classList.remove('open');
      });
      stockList.querySelectorAll('.stock-breakdown').forEach(el => el.remove());

      const legislatorQuery = normalizeSearchText(legislatorSearchInput.value.trim());
      const legislatorCards = Array.from(legislatorList.querySelectorAll('.stock-card'));
      legislatorCards.forEach(card => {
        const name = normalizeSearchText(card.getAttribute('data-name') || '');
        const area = normalizeSearchText(card.getAttribute('data-area') || '');
        const matched = !legislatorQuery || name.includes(legislatorQuery) || area.includes(legislatorQuery);
        card.classList.toggle('filtered-out', !matched);
        if (!matched) card.classList.remove('open');
      });
      legislatorList.querySelectorAll('.stock-breakdown').forEach(el => el.remove());

      updateVisibleRanks(stockList);
      updateVisibleRanks(legislatorList);
      stockSearchClear.classList.toggle('hidden', stockQuery.length === 0);
      legislatorSearchClear.classList.toggle('hidden', legislatorQuery.length === 0);
    }

    function openFirstVisibleCard(list) {
      const cards = Array.from(list.querySelectorAll('.stock-card'));
      const firstVisible = cards.find(card => !card.classList.contains('filtered-out'));
      if (!firstVisible) return;
      const header = firstVisible.querySelector('[data-expandable]');
      if (header instanceof HTMLElement) header.click();
    }

    viewButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const view = btn.getAttribute('data-view');
        if (view !== 'stock' && view !== 'legislator') return;
        currentView = view;
        applyView();
        openFirstVisibleCard(currentView === 'stock' ? stockList : legislatorList);
      });
    });

    stockSortButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const sort = btn.getAttribute('data-sort');
        if (sort !== 'person' && sort !== 'value') return;
        currentStockSort = sort;
        stockSortButtons.forEach(el => el.classList.toggle('active', el === btn));
        sortCards(stockList, sort);
      });
    });

    legislatorSortButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const sort = btn.getAttribute('data-sort');
        if (sort !== 'value' && sort !== 'return') return;
        currentLegislatorSort = sort;
        legislatorSortButtons.forEach(el => el.classList.toggle('active', el === btn));
        sortCards(legislatorList, sort);
      });
    });

    stockSearchInput.addEventListener('input', applySearchFilter);
    legislatorSearchInput.addEventListener('input', applySearchFilter);
    stockSearchClear.addEventListener('click', () => {
      stockSearchInput.value = '';
      applySearchFilter();
      stockSearchInput.focus();
    });
    legislatorSearchClear.addEventListener('click', () => {
      legislatorSearchInput.value = '';
      applySearchFilter();
      legislatorSearchInput.focus();
    });

    function closeOpenBreakdowns(list, exceptCard = null) {
      const openCards = Array.from(list.querySelectorAll('.stock-card.open'));
      openCards.forEach(card => {
        if (exceptCard && card === exceptCard) return;
        card.classList.remove('open');
        card.querySelectorAll('.stock-breakdown.open').forEach(el => el.classList.remove('open'));
      });
    }

    function handleCardToggle(e, list) {
      const rawTarget = e.target;
      const target = rawTarget instanceof Element
        ? rawTarget
        : (rawTarget instanceof Node ? rawTarget.parentElement : null);
      if (!target) return;
      const header = target.closest('[data-expandable]');
      if (!header) return;

      const card = header.closest('.stock-card');
      if (!card) return;

      closeOpenBreakdowns(list, card);

      const existing = card.querySelector('.stock-breakdown');
      if (existing) {
        const willOpen = !existing.classList.contains('open');
        closeOpenBreakdowns(list);
        existing.classList.toggle('open', willOpen);
        card.classList.toggle('open', willOpen);
        return;
      }

      const cardType = card.getAttribute('data-card-type');
      const breakdown = cardType === 'stock' ? buildStockBreakdown(card) : buildLegislatorBreakdown(card);
      if (!breakdown) return;
      closeOpenBreakdowns(list);
      card.appendChild(breakdown);
      card.classList.add('open');
    }

    stockList.addEventListener('click', e => handleCardToggle(e, stockList));
    legislatorList.addEventListener('click', e => handleCardToggle(e, legislatorList));

    // Default to stock view per product requirement.
    applyView();
    applySearchFilter();
    openFirstVisibleCard(stockList);
  }
</script>
