---
import Layout from '../layouts/Layout.astro';
import { getAllPeople, getPeopleMap } from '../lib/data';
import { existsSync, readdirSync } from 'node:fs';
import path from 'node:path';
import PersonMeta from '../components/PersonMeta.astro';
import InfoPopover from '../components/InfoPopover.astro';

const allPeople = getAllPeople();
const peopleMap = getPeopleMap();
const personByName = new Map(allPeople.map(l => [l.name, l]));

type DownloadMember = {
  name: string;
  party: string | null;
  date: string | null;
  hasData: boolean;
  defaultOrdinaryPdf: string | null;
  defaultOrdinaryJson: string | null;
  consolidatedJson: string | null;
  filings: {
    label: string;
    pdf: string | null;
    json: string | null;
  }[];
};

const DATA_ROOT = path.resolve(process.cwd(), 'data');

function safeReaddir(dir: string) {
  return existsSync(dir) ? readdirSync(dir) : [];
}

const consolidatedFiles = safeReaddir(path.join(DATA_ROOT, 'consolidated'))
  .filter(f => f.endsWith('.json'))
  .sort((a, b) => a.localeCompare(b, 'zh-TW'));
const consolidatedByName = new Map<string, { path: string; isPrefixed: boolean }>();
for (const f of consolidatedFiles) {
  const name = f.replace(/^\d+-/, '').replace(/\.json$/, '');
  const isPrefixed = /^\d+-/.test(f);
  const prev = consolidatedByName.get(name);
  if (!prev || (prev.isPrefixed && !isPrefixed)) {
    consolidatedByName.set(name, { path: `/data/consolidated/${f}`, isPrefixed });
  }
}

const SKIP_DIRS = new Set(['consolidated', '.tmp-extract']);
const memberDirs = (existsSync(DATA_ROOT) ? readdirSync(DATA_ROOT, { withFileTypes: true }) : [])
  .filter(d => d.isDirectory() && !d.name.startsWith('.') && !d.name.startsWith('_') && !SKIP_DIRS.has(d.name))
  .map(d => d.name);
const dirByName = new Map<string, string>();
for (const dirName of memberDirs) {
  const name = dirName.replace(/^\d+-/, '');
  dirByName.set(name, dirName);
}

const sectionLabel: Record<string, string> = {
  ordinary: '一般',
  change: '變動',
  trust: '信託',
  correction: '更補正',
};

function parseFilingLabel(base: string, section: string): string {
  const m = base.match(/^\d+-\d+(.+)$/);
  const suffix = (m?.[1] || '').trim();
  if (suffix) return suffix;
  return sectionLabel[section] || section;
}

function buildFilings(name: string) {
  const dir = dirByName.get(name);
  if (!dir) return { filings: [], defaultOrdinaryPdf: null as string | null, defaultOrdinaryJson: null as string | null };

  const personRoot = path.join(DATA_ROOT, dir);
  const sections = (existsSync(personRoot) ? readdirSync(personRoot, { withFileTypes: true }) : []).filter(d => d.isDirectory());
  const filings: { section: string; label: string; base: string; pdf: string | null; json: string | null }[] = [];

  for (const s of sections) {
    const section = s.name;
    const files = safeReaddir(path.join(personRoot, section));
    const baseMap = new Map<string, { pdf: string | null; extractedJson: string | null; rawJson: string | null }>();
    for (const file of files) {
      const isPdf = file.endsWith('.pdf');
      const isExtractedJson = file.endsWith('.extracted.json');
      const isRawJson = file.endsWith('.json') && !isExtractedJson;
      if (!isPdf && !isExtractedJson && !isRawJson) continue;

      const base = isExtractedJson ? file.slice(0, -'.extracted.json'.length) : file.replace(/\.(pdf|json)$/, '');
      if (!baseMap.has(base)) baseMap.set(base, { pdf: null, extractedJson: null, rawJson: null });
      const entry = baseMap.get(base)!;
      const rel = `/data/${dir}/${section}/${file}`;
      if (isPdf) entry.pdf = rel;
      if (isExtractedJson) entry.extractedJson = rel;
      if (isRawJson) entry.rawJson = rel;
    }
    for (const [base, entry] of baseMap.entries()) {
      filings.push({
        section,
        base,
        label: parseFilingLabel(base, section),
        pdf: entry.pdf,
        json: entry.extractedJson || entry.rawJson,
      });
    }
  }

  filings.sort((a, b) => b.base.localeCompare(a.base, 'zh-TW'));

  const ordinary = filings.filter(f => f.section === 'ordinary');
  const defaultOrdinary = ordinary[0] || null;

  return {
    filings: filings.map(f => ({ label: f.label, pdf: f.pdf, json: f.json })),
    defaultOrdinaryPdf: defaultOrdinary?.pdf || null,
    defaultOrdinaryJson: defaultOrdinary?.json || null,
  };
}

type DownloadMemberWithType = DownloadMember & { type: 'legislator' | 'mayor' };

const members: DownloadMemberWithType[] = Object.entries(peopleMap).map(([name, info]) => {
  const l = personByName.get(name);
  const filingInfo = buildFilings(name);
  return {
    name,
    type: info.type,
    party: l?.party || info.party || null,
    date: l?.date || null,
    hasData: !!l,
    defaultOrdinaryPdf: filingInfo.defaultOrdinaryPdf,
    defaultOrdinaryJson: filingInfo.defaultOrdinaryJson,
    consolidatedJson: consolidatedByName.get(name)?.path || null,
    filings: filingInfo.filings,
  };
});

// Group by type then by party
const partyOrder = ['民主進步黨', '中國國民黨', '台灣民眾黨'];

interface TypeSection {
  label: string;
  partyGroups: Map<string, DownloadMemberWithType[]>;
}

function buildTypeSection(label: string, typeMembers: DownloadMemberWithType[]): TypeSection {
  const partyGroups = new Map<string, DownloadMemberWithType[]>();
  for (const party of partyOrder) partyGroups.set(party, []);
  for (const m of typeMembers) {
    const party = m.party || '無黨籍';
    if (!partyGroups.has(party)) partyGroups.set(party, []);
    partyGroups.get(party)!.push(m);
  }
  // Remove empty groups
  for (const [k, v] of partyGroups) {
    if (v.length === 0) partyGroups.delete(k);
  }
  // Sort each group alphabetically
  for (const [, group] of partyGroups) {
    group.sort((a, b) => a.name.localeCompare(b.name, 'zh-TW'));
  }
  return { label, partyGroups };
}

const legislatorMembers = members.filter(m => m.type === 'legislator');
const mayorMembers = members.filter(m => m.type === 'mayor');

const typeSections: TypeSection[] = [];
if (legislatorMembers.length > 0) typeSections.push(buildTypeSection('立法委員', legislatorMembers));
if (mayorMembers.length > 0) typeSections.push(buildTypeSection('縣市首長', mayorMembers));

const partyColors: Record<string, string> = {
  '民主進步黨': 'var(--color-dpp)',
  '中國國民黨': 'var(--color-kmt)',
  '台灣民眾黨': 'var(--color-tpp)',
  '無黨籍': 'var(--color-independent)',
};
---

<Layout title="📥 資料下載">
  <section class="header">
    <div class="page-headline">
      <h1>📦 資料下載</h1>
      <InfoPopover>
        <p>此頁提供原始 PDF、擷取後 JSON 與整合 JSON；若有衝突，以監察院原始 PDF 為準。</p>
        <p>名單依人物類型（立法委員／縣市首長）與政黨分組。</p>
      </InfoPopover>
    </div>
    <p class="subtitle">下載財產申報 PDF 原檔及結構化 JSON</p>
  </section>

  <div class="search-box">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" id="search-input" placeholder="搜尋姓名..." />
  </div>

  <div class="bulk-download">
    <a class="dl-btn bulk-btn" href="/data/people-mapping.json" target="_blank" rel="noopener noreferrer">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      人物對照表 JSON
    </a>
  </div>

  <div id="party-list">
    {typeSections.map(section => (
      <div class="type-section">
        <h2 class="type-header">{section.label}</h2>
        {[...section.partyGroups.entries()].map(([party, partyMembers]) => (
          <div class="party-section" data-party={party}>
            <div class="party-header" data-collapsible>
              <div class="party-indicator" style={`background: ${partyColors[party] || 'var(--color-independent)'};`}></div>
              <span class="party-name" style={`color: ${partyColors[party] || 'var(--color-independent)'};`}>{party}</span>
              <span class="party-count">{partyMembers.length} 人</span>
              <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="party-members">
              {partyMembers.map(l => (
                <div class="member-row" data-name={l.name}>
                  <div class="member-info">
                    <div class="member-details">
                      <PersonMeta name={l.name} party={l.party} />
                    </div>
                    {l.date ? <span class="member-date">{`申報日 ${l.date.replace(/-/g, '/')}`}</span> : null}
                  </div>
                  <div class="member-actions">
                    {l.defaultOrdinaryPdf ? (
                      <a class="dl-btn icon-btn" href={l.defaultOrdinaryPdf} target="_blank" rel="noopener noreferrer" aria-label="下載一般 PDF">PDF</a>
                    ) : (
                      <span class="dl-btn icon-btn disabled" aria-disabled="true">PDF</span>
                    )}
                    {l.defaultOrdinaryJson ? (
                      <a class="dl-btn icon-btn" href={l.defaultOrdinaryJson} target="_blank" rel="noopener noreferrer" aria-label="下載一般 JSON">{'{ }'}</a>
                    ) : (
                      <span class="dl-btn icon-btn disabled" aria-disabled="true">{'{ }'}</span>
                    )}
                    <button class="dl-btn more-btn" data-expand-more>更多</button>
                  </div>
                </div>
                <div class="member-more">
                  {l.filings.map(f => (
                    <div class="filing-row">
                      <span class="filing-label">{f.label}</span>
                      <div class="filing-actions">
                        {f.pdf ? (
                          <a class="dl-btn icon-btn small" href={f.pdf} target="_blank" rel="noopener noreferrer" aria-label={`下載 ${f.label} PDF`}>PDF</a>
                        ) : (
                          <span class="dl-btn icon-btn small disabled" aria-disabled="true">PDF</span>
                        )}
                        {f.json ? (
                          <a class="dl-btn icon-btn small" href={f.json} target="_blank" rel="noopener noreferrer" aria-label={`下載 ${f.label} JSON`}>{'{ }'}</a>
                        ) : (
                          <span class="dl-btn icon-btn small disabled" aria-disabled="true">{'{ }'}</span>
                        )}
                      </div>
                    </div>
                  ))}
                  <div class="filing-row consolidated-row">
                    <span class="filing-label">整合資料</span>
                    <div class="filing-actions">
                      {l.consolidatedJson ? (
                        <a class="dl-btn icon-btn small" href={l.consolidatedJson} target="_blank" rel="noopener noreferrer" aria-label="下載整合 JSON">{'{ }'}</a>
                      ) : (
                        <span class="dl-btn icon-btn small disabled" aria-disabled="true">{'{ }'}</span>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</Layout>

<style>
  .header { margin-bottom: var(--section-gap); }
  h1 { font-size: 26px; font-weight: 900; letter-spacing: -0.02em; }
  .subtitle { font-size: 14px; color: var(--color-text-muted); margin-top: 6px; }

  .search-box {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    margin-bottom: 20px;
    background: var(--color-surface);
  }
  .search-box input {
    flex: 1;
    font-size: 14px;
    color: var(--color-text);
  }
  .search-box input::placeholder { color: var(--color-text-muted); }

  .bulk-download {
    margin-bottom: 20px;
  }
  .bulk-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
  }

  .type-section {
    margin-bottom: 8px;
  }
  .type-header {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.01em;
    padding: 12px 0 4px;
    border-bottom: 2px solid var(--color-text);
    margin-bottom: 8px;
  }

  #party-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .party-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0;
    cursor: pointer;
  }
  .party-indicator { width: 4px; height: 16px; border-radius: 2px; flex-shrink: 0; }
  .party-name { font-size: 15px; font-weight: 700; flex: 1; }
  .party-count { font-size: 13px; color: var(--color-text-muted); }
  .chevron { color: var(--color-text-muted); transition: transform 0.2s; }
  .party-section.collapsed .chevron { transform: rotate(-90deg); }
  .party-section.collapsed .party-members { display: none; }

  .member-row {
    display: flex;
    align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  .member-row:last-child { border-bottom: none; }

  .member-info {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    flex: 1;
    min-width: 0;
  }
  .member-details { min-width: 0; flex: 1; }
  .member-details :global(.person-meta) { max-width: 180px; }
  .member-date {
    font-size: 11px;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .member-actions { display: flex; gap: 8px; }
  .dl-btn {
    padding: 5px 12px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text);
    background: var(--color-surface);
    transition: background 0.15s;
  }
  .dl-btn:hover { background: var(--color-bg); }

  .member-row.hidden { display: none; }

  .icon-btn {
    width: 34px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-family: var(--font-mono);
    padding: 0;
  }
  .icon-btn.small { width: 30px; height: 24px; font-size: 11px; }
  .dl-btn.disabled { opacity: 0.35; pointer-events: none; }
  .more-btn { padding: 5px 10px; }

  .member-more {
    display: none;
    margin: 0 0 10px 24px;
    padding: 8px 10px;
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    background: #fafafa;
  }
  .member-row.expanded + .member-more { display: block; }
  .filing-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 6px 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  .filing-row:last-child { border-bottom: none; }
  .filing-label { font-size: 12px; color: var(--color-text-secondary); }
  .filing-actions { display: flex; gap: 6px; }
  .consolidated-row .filing-label { font-weight: 700; color: var(--color-text); }
</style>

<script>
  // Search
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const rows = document.querySelectorAll('.member-row');

  searchInput.addEventListener('input', () => {
    const query = searchInput.value.trim();
    rows.forEach(row => {
      const name = row.getAttribute('data-name') || '';
      const hidden = query !== '' && !name.includes(query);
      row.classList.toggle('hidden', hidden);
      if (hidden) row.classList.remove('expanded');
    });
  });

  // Collapse
  document.querySelectorAll('[data-collapsible]').forEach(header => {
    header.addEventListener('click', () => {
      header.closest('.party-section')?.classList.toggle('collapsed');
    });
  });

  // Expand per-member all filing types
  document.querySelectorAll('[data-expand-more]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const row = (e.currentTarget as HTMLElement).closest('.member-row');
      if (!row) return;
      row.classList.toggle('expanded');
    });
  });
</script>
