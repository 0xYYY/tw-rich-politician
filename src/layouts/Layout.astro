---
import '../styles/global.css';

interface Props {
  title: string;
  showNav?: boolean;
}

const { title, showNav = true } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class={showNav ? 'has-nav' : ''}>
  {showNav && (
    <nav class="top-nav">
      <div class="nav-tabs">
        <a href="/" class="nav-tab" data-page="/"><span class="tab-icon">🧭</span><span class="tab-label">首頁</span></a>
        <a href="/deposits" class="nav-tab" data-page="/deposits"><span class="tab-icon">💧</span><span class="tab-label">流動資產</span></a>
        <a href="/stocks" class="nav-tab" data-page="/stocks"><span class="tab-icon">📈</span><span class="tab-label">股票</span></a>
        <a href="/real-estate" class="nav-tab" data-page="/real-estate"><span class="tab-icon">🏠</span><span class="tab-label">不動產</span></a>
        <a href="/download" class="nav-tab" data-page="/download"><span class="tab-icon">📦</span><span class="tab-label">下載</span></a>
      </div>
    </nav>
  )}
  <main>
    <slot />
  </main>
</body>
</html>

<style>
  main {
    padding: var(--page-padding);
    padding-bottom: 40px;
  }

  .has-nav main {
    padding-top: 76px;
  }

  .top-nav {
    position: fixed;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 18px);
    max-width: 412px;
    padding: 6px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(20, 24, 36, 0.08);
    border-radius: 16px;
    box-shadow: 0 10px 22px rgba(11, 19, 32, 0.11);
    z-index: 100;
  }

  .nav-tabs {
    display: flex;
    gap: 4px;
    width: 100%;
  }

  .nav-tab {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: 6px 4px;
    font-size: 10px;
    font-weight: 600;
    color: rgba(30, 38, 52, 0.62);
    border-radius: 10px;
    transition: color 0.18s, background 0.18s, transform 0.18s;
  }
  .tab-icon {
    font-size: 13px;
    line-height: 1;
  }
  .tab-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .nav-tab.active {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: inset 0 0 0 1px rgba(27, 35, 49, 0.08);
    transform: translateY(-1px);
  }
</style>

<script define:vars={{ currentPath: Astro.url.pathname }}>
  document.querySelectorAll('.nav-tab').forEach(el => {
    const page = el.getAttribute('data-page');
    if ((page === '/' && currentPath === '/') || (page !== '/' && currentPath.startsWith(page))) {
      el.classList.add('active');
    }
  });
</script>
