---
import '../styles/shadcn.css';
import '../styles/global.css';

interface Props {
  title: string;
  showNav?: boolean;
  fullBleed?: boolean;
  bodyClass?: string;
}

const { title, showNav = true, fullBleed = false, bodyClass = 'blueprint-theme' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body
  class:list={[
    fullBleed ? 'min-h-dvh w-full' : 'mx-auto min-h-dvh w-full max-w-[430px]',
    showNav && 'has-nav',
    bodyClass,
  ]}
>
  {showNav && (
    <nav class="site-nav fixed left-1/2 top-2.5 z-[100] w-[calc(100%-18px)] max-w-[412px] -translate-x-1/2 rounded-none border border-[var(--border-grid)] p-1.5">
      <div class="flex w-full gap-1">
        <a href="/" class="nav-tab bp-body flex min-w-0 flex-1 flex-col items-center justify-center gap-0 rounded-none px-1 py-2 text-[11px] font-medium text-[var(--text-secondary)] transition-[color,background,transform] duration-200" data-page="/"><span class="tab-icon">🧭</span><span class="tab-label overflow-hidden text-ellipsis whitespace-nowrap tracking-[0.01em]">首頁</span></a>
        <a href="/deposits" class="nav-tab bp-body flex min-w-0 flex-1 flex-col items-center justify-center gap-0 rounded-none px-1 py-2 text-[11px] font-medium text-[var(--text-secondary)] transition-[color,background,transform] duration-200" data-page="/deposits"><span class="tab-icon">💰</span><span class="tab-label overflow-hidden text-ellipsis whitespace-nowrap tracking-[0.01em]">存款排名</span></a>
        <a href="/stocks" class="nav-tab bp-body flex min-w-0 flex-1 flex-col items-center justify-center gap-0 rounded-none px-1 py-2 text-[11px] font-medium text-[var(--text-secondary)] transition-[color,background,transform] duration-200" data-page="/stocks"><span class="tab-icon">📈</span><span class="tab-label overflow-hidden text-ellipsis whitespace-nowrap tracking-[0.01em]">股票持股</span></a>
        <a href="/real-estate" class="nav-tab bp-body flex min-w-0 flex-1 flex-col items-center justify-center gap-0 rounded-none px-1 py-2 text-[11px] font-medium text-[var(--text-secondary)] transition-[color,background,transform] duration-200" data-page="/real-estate"><span class="tab-icon">🏠</span><span class="tab-label overflow-hidden text-ellipsis whitespace-nowrap tracking-[0.01em]">不動產</span></a>
        <a href="/download" class="nav-tab bp-body flex min-w-0 flex-1 flex-col items-center justify-center gap-0 rounded-none px-1 py-2 text-[11px] font-medium text-[var(--text-secondary)] transition-[color,background,transform] duration-200" data-page="/download"><span class="tab-icon">📦</span><span class="tab-label overflow-hidden text-ellipsis whitespace-nowrap tracking-[0.01em]">資料下載</span></a>
      </div>
    </nav>
  )}
  <main
    class:list={[
      fullBleed ? 'px-0 pb-0' : 'px-[var(--page-padding)] pb-10',
      showNav ? 'pt-[66px]' : fullBleed ? 'pt-0' : 'pt-[var(--page-padding)]',
    ]}
  >
    <slot />
  </main>
</body>
</html>

<script define:vars={{ currentPath: Astro.url.pathname }}>
  const nav = document.querySelector('.site-nav');
  const updateNavScrollState = () => {
    nav?.classList.toggle('is-scrolled', window.scrollY > 6);
  };
  updateNavScrollState();
  window.addEventListener('scroll', updateNavScrollState, { passive: true });

  document.querySelectorAll('.nav-tab').forEach(el => {
    const page = el.getAttribute('data-page');
    if ((page === '/' && currentPath === '/') || (page !== '/' && currentPath.startsWith(page))) {
      el.classList.add('active');
    }
  });
</script>
