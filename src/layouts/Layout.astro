---
import '../styles/global.css';

interface Props {
  title: string;
  showNav?: boolean;
}

const { title, showNav = true } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class={showNav ? 'has-nav' : ''}>
  {showNav && (
    <nav class="top-nav">
      <a href="/" class="nav-home" aria-label="首頁">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </a>
      <div class="nav-tabs">
        <a href="/deposits" class="nav-tab" data-page="/deposits">存款</a>
        <a href="/stocks" class="nav-tab" data-page="/stocks">股票</a>
        <a href="/real-estate" class="nav-tab" data-page="/real-estate">不動產</a>
        <a href="/download" class="nav-tab" data-page="/download">下載</a>
      </div>
    </nav>
  )}
  <main>
    <slot />
  </main>
</body>
</html>

<style>
  main {
    padding: var(--page-padding);
    padding-bottom: 40px;
  }

  .has-nav main {
    padding-top: 60px;
  }

  .top-nav {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 430px;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 var(--page-padding);
    height: 48px;
    background: rgba(250, 248, 245, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-light);
    z-index: 100;
  }

  .nav-home {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .nav-home:hover { color: var(--color-text); }

  .nav-tabs {
    display: flex;
    gap: 2px;
    flex: 1;
    justify-content: flex-end;
  }

  .nav-tab {
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-muted);
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-tab:hover {
    color: var(--color-text-secondary);
  }
  .nav-tab.active {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.05);
  }
</style>

<script define:vars={{ currentPath: Astro.url.pathname }}>
  document.querySelectorAll('.nav-tab').forEach(el => {
    const page = el.getAttribute('data-page');
    if (page === currentPath) {
      el.classList.add('active');
    }
  });
</script>
